# ── Backend Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in values for local development.
# On Render, set these in the Environment tab of your service dashboard.

# CORS: comma-separated allowed origins (set to your Vercel domain in production)
API_ALLOW_ORIGINS=http://localhost:3000

# Path to the trained CNN checkpoint
MODEL_CHECKPOINT=outputs/checkpoints/best_model.pth

# Directory containing LCS artifacts (lcs_model.pkl, scaler.pkl, selector.pkl)
LCS_DIR=outputs/lcs

# Require approved_model.json manifest before loading LCS (true/false)
REQUIRE_APPROVED_LCS=false

# Anomaly probability threshold (0.0 – 1.0)
ANOMALY_THRESHOLD=0.50

# Maximum upload size in MB
MAX_UPLOAD_MB=25
